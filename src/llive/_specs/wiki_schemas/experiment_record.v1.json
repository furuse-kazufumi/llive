{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llive.dev/wiki_schemas/experiment_record.v1.json",
  "title": "experiment_record (LLW-03)",
  "type": "object",
  "required": ["candidate_id", "baseline", "outcome"],
  "additionalProperties": true,
  "properties": {
    "candidate_id": { "type": "string" },
    "baseline":     { "type": "string" },
    "outcome":      { "enum": ["accepted", "rejected", "rolled_back", "in_progress"] },
    "metrics":      { "type": "object" },
    "notes":        { "type": "string" }
  }
}
