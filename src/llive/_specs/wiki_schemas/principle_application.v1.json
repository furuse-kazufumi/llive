{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llive.dev/wiki_schemas/principle_application.v1.json",
  "title": "principle_application (LLW-03)",
  "type": "object",
  "required": ["principle_id", "application"],
  "additionalProperties": true,
  "properties": {
    "principle_id": { "type": "integer", "minimum": 1, "maximum": 40 },
    "principle_name": { "type": "string" },
    "application":  { "type": "string" },
    "evidence":     { "type": "array", "items": { "type": "string" } },
    "outcome":      { "type": "string" }
  }
}
